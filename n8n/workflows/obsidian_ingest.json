{
  "name": "Obsidian Ingest Workflow",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 2 * * *"
            }
          ]
        }
      },
      "name": "Scheduled Trigger",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "url": "http://backend:8000/ingest",
        "method": "POST"
      },
      "name": "Trigger Backend Ingest",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [500, 300]
    }
  ],
  "connections": {
    "Scheduled Trigger": {
      "main": [[{"node": "Trigger Backend Ingest", "type": "main", "index": 0}]]
    }
  },
  "active": false,
  "settings": {},
  "id": "obsidian-ingest"
}
