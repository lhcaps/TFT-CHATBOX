# ============================================
# TFT Local Copilot - Environment Variables
# ============================================

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_KEEP_ALIVE=15m

# Supabase Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# AI Models
CHAT_MODEL=qwen3:8b
EMBEDDING_MODEL=qwen3-embedding:4b
EMBEDDING_DIMENSIONS=1024

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Obsidian Vault (adjust path to your vault)
OBSIDIAN_VAULT_PATH=D:/Obsidian/Vault

# n8n Configuration
WEBHOOK_URL=http://localhost:5678/
N8N_PROXY_HOPS=1
GENERIC_TIMEZONE=Asia/Ho_Chi_Minh
TZ=Asia/Ho_Chi_Minh

# API Auth (shared secret between n8n and backend)
# Generate a strong random string: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=<your-secret-here>
